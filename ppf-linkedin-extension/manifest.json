{
  "manifest_version": 3,
  "name": "PPF eRec – LinkedIn Matcher",
  "version": "0.3.1",
  "description": "Zobrazí odkaz na kandidáta v PPF eRec přímo na LinkedIn profilu.",
  "permissions": [
    "cookies",
    "activeTab",
    "alarms",
    "storage"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://www.linkedin.com/search/*",
        "https://www.linkedin.com/talent/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "PPF eRec – LinkedIn Matcher"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
